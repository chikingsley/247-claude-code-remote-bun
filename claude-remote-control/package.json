{
  "name": "247",
  "version": "2.44.2",
  "private": true,
  "description": "247 - Remote web terminal for Claude Code. Access AI coding sessions from your phone, tablet, or any browser 24/7. Built with Next.js, WebSocket, xterm.js, and tmux for persistent terminal sessions.",
  "keywords": [
    "claude-code",
    "remote-terminal",
    "web-terminal",
    "ai-coding",
    "terminal",
    "websocket",
    "tmux",
    "xterm",
    "nextjs",
    "mobile-terminal",
    "ssh-alternative",
    "remote-development",
    "quivr"
  ],
  "author": "Quivr (Y Combinator W24)",
  "license": "MIT",
  "homepage": "https://247.quivr.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/QuivrHQ/247-claude-code-remote"
  },
  "bugs": {
    "url": "https://github.com/QuivrHQ/247-claude-code-remote/issues"
  },
  "scripts": {
    "dev": "bun run --parallel --filter '*' --if-present dev",
    "build": "bun run --filter '*' --if-present build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun run --filter '*' --if-present typecheck",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "test": "bun run --filter '*' --if-present test",
    "test:verbose": "bun run --filter '*' --if-present test",
    "test:unit": "bun run --filter '*' --if-present test:unit",
    "test:integration": "bun run --filter '*' --if-present test:integration",
    "test:coverage": "bun run --filter '*' --if-present test:coverage",
    "duplication": "jscpd",
    "duplication:check": "jscpd --exitCode 1",
    "deadcode": "knip",
    "deadcode:fix": "knip --fix",
    "dev:web": "bun run --filter 247-web dev",
    "dev:agent": "bun run --filter 247-agent dev",
    "release": "bun scripts/release/index.ts",
    "prepare": "echo 'Husky hooks configured at repo root'"
  },
  "devDependencies": {
    "chalk": "^5.3.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "knip": "^5.82.1",
    "lint-staged": "^15.4.3",
    "ora": "^8.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
