{
  "name": "247-agent",
  "version": "2.44.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun run ../../tools/test-isolated.ts tests",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "247-shared": "workspace:*",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^22.10.5",
    "@types/web-push": "^3.6.4",
    "execa": "^9.6.1",
    "typescript": "^5.7.2"
  }
}
